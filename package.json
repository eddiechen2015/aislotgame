{
  "name": "asian-tour-slot",
  "version": "0.1.0",
  "description": "Asian Tour - 243-ways cascading slot (ASIAN-TOUR-01)",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server/index.js",
    "dev": "ts-node src/server/index.ts",
